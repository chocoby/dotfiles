{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(cat *)",
      "Bash(curl *)",
      "Bash(docker compose build *)",
      "Bash(docker compose down *)",
      "Bash(docker compose exec *)",
      "Bash(docker compose logs *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose run *)",
      "Bash(docker compose up *)",
      "Bash(docker build *)",
      "Bash(docker logs *)",
      "Bash(docker run *)",
      "Bash(docker stop *)",
      "Bash(find *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh release list *)",
      "Bash(gh run view *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git pull *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(mise install *)",
      "Bash(mise tasks)",
      "Bash(mkdir *)",
      "Bash(npm install *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "List(*)"
    ],
    "ask": [
      "Bash(gh api *)",
      "Bash(gh pr create *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(jj git push *)"
    ],
    "deny": [
      "Bash(rm -rf ../*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(mkdir /*)",
      "Bash(sudo *)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.gem/credentials)",
      "Read(./.env*)",
      "Write(.git/**)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)",
      "Bash(gh pr reopen *)",
      "Bash(gh pr review *)",
      "Bash(gh pr comment *)",
      "Bash(gh release create *)",
      "Bash(gh release delete *)",
      "Bash(gh repo create *)",
      "Bash(gh repo fork *)",
      "Bash(gh repo delete *)",
      "Bash(gh issue create *)",
      "Bash(gh issue close *)",
      "Bash(gh issue comment *)",
      "Bash(gh gist create *)",
      "Bash(gh workflow run *)",
      "Bash(gh auth login *)",
      "Bash(gh secret set *)",
      "Bash(gh secret delete *)",
      "Bash(gh variable set *)",
      "Bash(gh variable delete *)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/commands/notify.sh notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/commands/notify.sh stop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "oh-my-claudecode@omc": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    }
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
