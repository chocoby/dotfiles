#!/usr/bin/env bash
# Generate a commit message via Claude and print the git commit command

set -euo pipefail

commit_msg=$(claude -p '/generate-commit-message' 2>/dev/null)

if [[ -z "$commit_msg" ]]; then
  echo "Error: failed to generate commit message" >&2
  exit 1
fi

git commit -e -m "$commit_msg"
